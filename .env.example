# Base URL of calorie-tracker-backend (no trailing slash), e.g. http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Sign-In (Firebase / OAuth client IDs from Google Cloud Console).
# Not required for email/password sign-in. On Android, omit EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID until
# you add Google Sign-In (package com.rajrsoftware.calorieTracker + SHA-1 for your keystore).
# iOS (simulator and device): set EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID to the iOS OAuth client ID
# (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → iOS).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional: Firebase Auth ID token for local API testing when no user is signed in.
# Ignored while a Firebase session exists (the app sends the real user's ID token).
EXPO_PUBLIC_MOCK_ID_TOKEN=

# Optional: real Firebase web config (replace placeholders in app.config.ts / EAS secrets).
# Use the Web app snippet from Firebase Console → Project settings (not iOS/Android alone).
# EXPO_PUBLIC_FIREBASE_APP_ID must contain ":web:" (Firebase JS SDK).
# auth/configuration-not-found: Firebase Console → Authentication → Sign-in methods → enable Email/Password;
# wrong/mixed Web app IDs; Identity Toolkit API disabled; API key restrictions blocking Identity Toolkit;
# or empty EXPO_PUBLIC_* in your shell (unset those vars so .env wins).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# EAS / CI: Expo project ID from https://expo.dev (optional until you run `eas init`)
EAS_PROJECT_ID=
